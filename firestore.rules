rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function hasCreateFields() {
      return request.resource.data.keys().hasAll([
          'seasonId',
          'gameId',
          'playerId',
          'nickname',
          'score',
          'source',
          'createdAt',
          'updatedAt',
          'lastSubmittedAt'
        ]) &&
        request.resource.data.keys().hasOnly([
          'seasonId',
          'gameId',
          'playerId',
          'nickname',
          'score',
          'source',
          'createdAt',
          'updatedAt',
          'lastSubmittedAt'
        ]);
    }

    function hasRunCreateFields() {
      return request.resource.data.keys().hasAll([
          'entryId',
          'seasonId',
          'gameId',
          'playerId',
          'nickname',
          'score',
          'source',
          'createdAt',
          'updatedAt',
          'lastSubmittedAt'
        ]) &&
        request.resource.data.keys().hasOnly([
          'entryId',
          'seasonId',
          'gameId',
          'playerId',
          'nickname',
          'score',
          'source',
          'createdAt',
          'updatedAt',
          'lastSubmittedAt'
        ]);
    }

    function getMaxScore(gameId) {
      return gameId == 'connectivity-probe' ? 0 :
        gameId == 'dino-run-1' ? 999999 :
        gameId == 'dino-run-2' ? 999999 :
        gameId == 'dino-run-hard' ? 999999 :
        gameId == 'lane-dash' ? 999999 :
        gameId == 'ocean-tap' ? 999999 :
        gameId == 'parcel-stack' ? 999999 :
        gameId == 'wing-boss' ? 999999 :
        gameId == 'wing-tap-1' ? 999999 :
        gameId == 'wing-tap-2' ? 999999 :
        -1;
    }

    function isSupportedGameId(gameId) {
      return getMaxScore(gameId) >= 0;
    }

    function hasServerCreateTimestamps() {
      return request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.lastSubmittedAt == request.time;
    }

    function hasServerUpdateTimestamps() {
      return request.resource.data.updatedAt == request.time &&
        request.resource.data.lastSubmittedAt == request.time;
    }

    function isValidCommon(seasonId, gameId, playerId) {
      return isSupportedGameId(gameId) &&
        request.resource.data.seasonId == seasonId &&
        request.resource.data.gameId == gameId &&
        request.resource.data.playerId == playerId &&
        request.resource.data.source == 'livelysam' &&
        request.resource.data.nickname is string &&
        request.resource.data.nickname.size() > 0 &&
        request.resource.data.nickname.size() <= 12 &&
        request.resource.data.score is int &&
        request.resource.data.score >= 0 &&
        request.resource.data.score <= getMaxScore(gameId);
    }

    function isAllowedRunSlot(entryId, playerId) {
      return entryId == playerId + '__top1' ||
        entryId == playerId + '__top2' ||
        entryId == playerId + '__top3';
    }

    match /minigameLeaderboards/{seasonId}/games/{gameId}/entries/{playerId} {
      allow read: if true;

      allow create: if request.auth != null &&
        request.auth.uid == playerId &&
        hasCreateFields() &&
        isValidCommon(seasonId, gameId, playerId) &&
        hasServerCreateTimestamps();

      allow update: if request.auth != null &&
        request.auth.uid == playerId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'nickname',
          'score',
          'updatedAt',
          'lastSubmittedAt'
        ]) &&
        isValidCommon(seasonId, gameId, playerId) &&
        hasServerUpdateTimestamps() &&
        request.resource.data.score >= resource.data.score &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.source == resource.data.source;

      allow delete: if false;
    }

    match /minigameLeaderboards/{seasonId}/games/{gameId}/runs/{entryId} {
      allow read: if true;

      allow create: if request.auth != null &&
        isAllowedRunSlot(entryId, request.auth.uid) &&
        request.resource.data.entryId == entryId &&
        request.resource.data.playerId == request.auth.uid &&
        hasRunCreateFields() &&
        isValidCommon(seasonId, gameId, request.auth.uid) &&
        hasServerCreateTimestamps();

      allow update: if request.auth != null &&
        isAllowedRunSlot(entryId, request.auth.uid) &&
        resource.data.entryId == entryId &&
        resource.data.playerId == request.auth.uid &&
        hasRunCreateFields() &&
        request.resource.data.entryId == resource.data.entryId &&
        request.resource.data.seasonId == resource.data.seasonId &&
        request.resource.data.gameId == resource.data.gameId &&
        request.resource.data.playerId == resource.data.playerId &&
        request.resource.data.source == resource.data.source &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'nickname',
          'score',
          'updatedAt',
          'lastSubmittedAt'
        ]) &&
        isValidCommon(seasonId, gameId, request.auth.uid) &&
        hasServerUpdateTimestamps() &&
        request.resource.data.score >= resource.data.score &&
        request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if false;
    }
  }
}

