{
  "schoolName": {
    "type": "textbox",
    "value": "",
    "text": "학교명 (예: 세종고등학교)"
  },
  "neisApiKey": {
    "type": "textbox",
    "value": "",
    "text": "(고급) NEIS 직접 키"
  },
  "weatherProviderMode": {
    "type": "dropdown",
    "value": 0,
    "text": "날씨 연결 방식",
    "items": [
      "기본 서버 사용",
      "내 API 키 사용"
    ]
  },
  "weatherApiKey": {
    "type": "textbox",
    "value": "",
    "text": "날씨 개인 API 키 (선택)"
  },
  "theme": {
    "type": "dropdown",
    "value": 1,
    "text": "테마 선택",
    "items": [
      "벚꽃 파스텔",
      "오션 브리즈",
      "민트 가든",
      "피치 코랄",
      "라벤더 드림",
      "써니 레몬",
      "아이스 그레이",
      "선셋"
    ]
  },
  "widgetOpacity": {
    "type": "slider",
    "value": 75,
    "text": "위젯 투명도 (%)",
    "min": 10,
    "max": 100,
    "step": 5
  },
  "fontSize": {
    "type": "slider",
    "value": 14,
    "text": "기본 글자 크기 (px)",
    "min": 10,
    "max": 24,
    "step": 1
  },
  "clockFormat": {
    "type": "dropdown",
    "value": 1,
    "text": "시계 형식",
    "items": [
      "12시간",
      "24시간"
    ]
  },
  "showAnalogClock": {
    "type": "checkbox",
    "value": true,
    "text": "아날로그 시계 표시"
  },
  "showSeconds": {
    "type": "checkbox",
    "value": true,
    "text": "초 표시"
  },
  "grade": {
    "type": "dropdown",
    "value": 0,
    "text": "학년",
    "items": [
      "1학년",
      "2학년",
      "3학년"
    ]
  },
  "classNum": {
    "type": "textbox",
    "value": "1",
    "text": "반"
  },
  "startTime": {
    "type": "textbox",
    "value": "08:20",
    "text": "일과 시작 시간 (HH:MM)"
  },
  "morningMinutes": {
    "type": "slider",
    "value": 10,
    "text": "조회 시간 (분)",
    "min": 5,
    "max": 30,
    "step": 5
  },
  "classMinutes": {
    "type": "slider",
    "value": 50,
    "text": "수업 시간 (분)",
    "min": 40,
    "max": 60,
    "step": 5
  },
  "breakMinutes": {
    "type": "slider",
    "value": 10,
    "text": "쉬는 시간 (분)",
    "min": 5,
    "max": 20,
    "step": 5
  },
  "lunchMinutes": {
    "type": "slider",
    "value": 60,
    "text": "점심 시간 (분)",
    "min": 40,
    "max": 80,
    "step": 5
  },
  "lunchAfterPeriod": {
    "type": "dropdown",
    "value": 1,
    "text": "점심 시간 위치",
    "items": [
      "3교시 후",
      "4교시 후",
      "5교시 후"
    ]
  },
  "totalPeriods": {
    "type": "dropdown",
    "value": 1,
    "text": "정규 교시 수",
    "items": [
      "6교시",
      "7교시"
    ]
  },
  "afterSchoolEnabled": {
    "type": "checkbox",
    "value": false,
    "text": "방과후 수업 사용"
  },
  "afterSchoolMinutes": {
    "type": "slider",
    "value": 70,
    "text": "방과후 수업 시간 (분)",
    "min": 60,
    "max": 90,
    "step": 5
  },
  "afterSchoolDays": {
    "type": "textbox",
    "value": "1,3,5",
    "text": "방과후 수업 요일 (1=월, 5=금, 쉼표 구분)"
  }
}
